# Translate-R Mobile Environment Variables
# Copy this to .env and fill in your values

# Supabase (public keys only — safe for client-side)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key

# Backend API URL (your Vercel deployment)
EXPO_PUBLIC_API_URL=https://translate-r-api.vercel.app

# WebSocket server URL (for STT streaming — Railway/Render deployment)
EXPO_PUBLIC_WS_URL=wss://translate-r-ws.up.railway.app
