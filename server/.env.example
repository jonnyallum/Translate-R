# Translate-R Server Environment Variables
# Copy this to .env and fill in your values

# ============================================
# Supabase
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key

# ============================================
# Deepgram (STT)
# ============================================
# Get your key at: https://console.deepgram.com
DEEPGRAM_API_KEY=your-deepgram-api-key

# ============================================
# OpenAI (Translation)
# ============================================
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# ============================================
# Daily.co (WebRTC Video)
# ============================================
# Get your key at: https://dashboard.daily.co/developers
DAILY_API_KEY=your-daily-api-key

# ============================================
# Stripe (Subscriptions)
# ============================================
# Get your keys at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
# Set up webhook at: https://dashboard.stripe.com/webhooks
# Events: checkout.session.completed, customer.subscription.*
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# ============================================
# WebSocket Server
# ============================================
WS_PORT=3001
